            "allowedTypes": [
                "images"
            ]
        },
        "skills": {
            "type": "json",
            "default": []
        },
        "experience": {
            "type": "richtext"
        },
        "email": {
            "type": "email"
        },
        "phone": {
            "type": "string"
        },
        "location": {
            "type": "string"
        },
        "resume": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "files"
            ]
        }
